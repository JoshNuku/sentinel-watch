# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/project-orion
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/project-orion

# CORS Configuration (Frontend URL)
FRONTEND_URL=http://localhost:3000

# Huawei Cloud Simple Message Notification (SMN)
HUAWEI_SMN_REGION=cn-north-1
HUAWEI_SMN_ACCESS_KEY=your_access_key_here
HUAWEI_SMN_SECRET_KEY=your_secret_key_here
HUAWEI_SMN_TOPIC_URN=urn:smn:cn-north-1:xxxx:orion-alerts
HUAWEI_SMN_PHONE_NUMBERS=+86xxxxxxxxxx,+86yyyyyyyyyy

# Alert Configuration
ALERT_CONFIDENCE_THRESHOLD=0.75
